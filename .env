# ==============================================================================
# APPLICATION ENVIRONMENT
# ==============================================================================

NODE_ENV=development
PORT=5001

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,http://127.0.0.1:3000

# ==============================================================================
# POSTGRESQL DATABASE
# ==============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=accessibility_pro_db
DB_USER=postgres
DB_PASSWORD=your_secure_postgres_password_here

DATABASE_URL=postgresql://postgres:your_secure_postgres_password_here@localhost:5432/accessibility_pro_db

# ==============================================================================
# JWT
# ==============================================================================

JWT_SECRET=replace_with_a_long_random_secret_key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_second_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ==============================================================================
# FIREBASE (Expo Client)
# ==============================================================================

EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ==============================================================================
# API
# ==============================================================================

EXPO_PUBLIC_API_URL=https://accessibilitypro.onrender.com/api/v1

# ==============================================================================
# GOOGLE MAPS
# ==============================================================================

EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ==============================================================================
# CLOUDINARY (Optional)
# ==============================================================================

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==============================================================================
# EMAIL (Optional)
# ==============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AccessibilityPro <noreply@accessibilitypro.com>

# ==============================================================================
# STORAGE
# ==============================================================================

UPLOAD_DIRECTORY=uploads
MAX_UPLOAD_SIZE=10485760

# ==============================================================================
# LOGGING
# ==============================================================================

LOG_LEVEL=debug
